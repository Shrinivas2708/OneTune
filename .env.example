# OneTune environment variables
# Copy to .env and adjust values.

# ─── API (required) ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://mongodb:27017/OneTune
JWT_SECRET=change-me-in-production
EXTRACTOR_URL=http://extractor:8001
JIOSAAVN_URL=http://jiosaavn:3000
SPOTIFY_URL=http://spotify:8003
LOG_LEVEL=info

# ─── MongoDB (local Docker) ───────────────────────────────────────────────────
MONGO_INITDB_DATABASE=OneTune

# ─── Extractor / Spotify (internal) ───────────────────────────────────────────
EXTRACTOR_PORT=8001
SPOTIFY_PORT=8003

# YouTube extraction (extractor service)
# Docker / VPS: mount secrets/youtube-cookies.txt (see docker-compose.yml)
# Render (no file upload): use YTDLP_COOKIES_BASE64 — run scripts/encode-youtube-cookies.ps1
# YTDLP_COOKIE_FILE=/secrets/youtube-cookies.txt
# YTDLP_COOKIES_BASE64=<output from encode-youtube-cookies.ps1>
# YTDLP_COOKIES_FROM_BROWSER=chrome

# ─── MongoDB Atlas (Render / cloud) ───────────────────────────────────────────
# Create M0 cluster → Database user → Network Access 0.0.0.0/0 → paste URI:
# MONGODB_URI=mongodb+srv://OneTune:PASSWORD@cluster0.xxxxx.mongodb.net/OneTune?retryWrites=true&w=majority

# ─── Render (set on OneTune-api service, not in git) ────────────────────────
# NODE_ENV=production
# JWT_SECRET=<openssl rand -base64 48>
# EXTRACTOR_URL=https://OneTune-extractor.onrender.com
# SPOTIFY_URL=https://OneTune-spotify.onrender.com
# JIOSAAVN_URL=https://OneTune-jiosaavn.onrender.com
# See docs/DEPLOYMENT-RENDER.md for full guide.

# ─── Production VPS (docker-compose.prod.yml) ─────────────────────────────────
# Generate: openssl rand -base64 48
# JWT_SECRET=<strong-random-secret>
# NODE_ENV=production
#
# DNS A record → your VPS IP before running init-letsencrypt.sh
OneTune_DOMAIN=api.yourdomain.com
CERTBOT_EMAIL=you@example.com
USE_HTTPS=false
# After certs: USE_HTTPS=true and recreate nginx

# ─── Mobile (Expo) ────────────────────────────────────────────────────────────
# Expo reads .env from apps/mobile/ when running Metro or building APK.
# Repo-root .env is for Docker/API only.
#
# | Target              | EXPO_PUBLIC_API_URL                              |
# |---------------------|--------------------------------------------------|
# | Web                 | http://localhost:3000                            |
# | Android emulator    | http://10.0.2.2:3000                             |
# | Physical phone      | http://<your-pc-lan-ip>:3000                     |
# | Render / production | https://api.onetune.shribuilds.in                |
# | VPS production      | https://api.yourdomain.com                       |
#
# Dev: npx expo run:android (once), then npx expo start --dev-client
# Release APK: cd apps/mobile && bun run build:android:standalone
# Guides: docs/DEVELOPMENT.md, docs/DEPLOYMENT.md
#
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Feature flags (optional) ─────────────────────────────────────────────────
# FF_VIDEO_PLAYBACK=false
# FF_SPOTIFY_IMPORT=true
# FF_PROXIED_STREAMING=false
