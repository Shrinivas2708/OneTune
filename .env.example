# VibeVault environment variables
# Copy to .env and adjust values.

# ─── API (required) ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://mongodb:27017/vibevault
JWT_SECRET=change-me-in-production
EXTRACTOR_URL=http://extractor:8001
JIOSAAVN_URL=http://jiosaavn:3000
SPOTIFY_URL=http://spotify:8003
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_INITDB_DATABASE=vibevault

# ─── Extractor / Spotify (internal) ───────────────────────────────────────────
EXTRACTOR_PORT=8001
SPOTIFY_PORT=8003

# ─── Production VPS (docker-compose.prod.yml) ─────────────────────────────────
# Generate: openssl rand -base64 48
# JWT_SECRET=<strong-random-secret>
# NODE_ENV=production
#
# DNS A record → your VPS IP before running init-letsencrypt.sh
VIBEVAULT_DOMAIN=api.yourdomain.com
CERTBOT_EMAIL=you@example.com
USE_HTTPS=false
# After certs: USE_HTTPS=true and recreate nginx

# ─── Mobile (EAS builds — set in eas.json or EAS Secrets) ─────────────────────
# Local dev / emulator:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
#   Android emulator: http://10.0.2.2:3000
# Production / preview (must match VIBEVAULT_DOMAIN with https):
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Feature flags (optional) ─────────────────────────────────────────────────
# FF_VIDEO_PLAYBACK=false
# FF_SPOTIFY_IMPORT=true
# FF_PROXIED_STREAMING=false
