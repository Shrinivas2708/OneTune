{
  "scheme": "vibevault",
  "userInterfaceStyle": "dark",
  "orientation": "portrait",
  "backgroundColor": "#121212",
  "splash": {
    "backgroundColor": "#121212",
    "resizeMode": "contain"
  },
  "ios": {
    "bundleIdentifier": "com.vibevault.app",
    "infoPlist": {
      "UIBackgroundModes": ["audio"]
    }
  },
  "android": {
    "package": "com.vibevault.app",
    "permissions": []
  },
  "web": {
    "output": "static"
  },
  "plugins": [
    "expo-router",
    "expo-font",
    "expo-dev-client",
    [
      "expo-splash-screen",
      {
        "backgroundColor": "#121212"
      }
    ],
    [
      "expo-build-properties",
      {
        "android": {
          "usesCleartextTraffic": true
        }
      }
    ]
  ],
  "name": "VibeVault",
  "slug": "vibevault",
  "version": "1.0.0",
  "extra": {
    "router": {
      "origin": "https://vibevault.app"
    },
    "eas": {
      "projectId": "122c1b04-d383-4bc5-8eed-15c308ac28b6"
    }
  },
  "runtimeVersion": {
    "policy": "appVersion"
  },
  "updates": {
    "url": "https://u.expo.dev/122c1b04-d383-4bc5-8eed-15c308ac28b6"
  }
}
